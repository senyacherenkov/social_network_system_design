// Use DBML to define your database structure
// Docs: https://dbml.dbdiagram.io/docs

Table postComments {
  id integer [primary key]
  post_id integer
  user_id integer
  body text [note: 'comment for post']
}

Table hashTags {
  id integer [primary key]
  post_id integer
  hashtag varchar
}

Table userProfiles {
  id integer [primary key]
  realationGraph_id integer
  profile json
}

Table userChats {
  id integer [primary key]
  user_id integer [not null]
  chat_id integer
}

Table userPosts {
  id integer [primary key]
  title varchar
  body text [note: 'Content of the post']
  user_id integer [not null]
  created_at timestamp
  media_id integer
  likes integer
  views integer
}

Ref postComments: postComments.post_id > userPosts.id // many-to-one

Ref: hashTags.post_id > userPosts.id

Ref: userProfiles.id > userPosts.user_id

Ref: userProfiles.id > userChats.user_id

